rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Generic Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // 0.2 Application specific helpers
    function isAdmin() {
      return isSignedIn() && 
        (request.auth.token.email in ["gonzalo.sabsay@gmail.com", "gonzalo.sabsay@hotmail.com"] && 
         request.auth.token.email_verified == true);
    }

    // 1. Validation Blueprints
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'firstName', 'lastName', 'username', 'email', 'birthDate', 'phoneNumber', 'role']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.role in ['client', 'professional'] &&
             (!('avgRating' in data) || data.avgRating is number) &&
             (!('numReviews' in data) || data.numReviews is number) &&
             (!('specialties' in data) || data.specialties is list) &&
             (!('isAdmin' in data) || data.isAdmin is bool);
    }

    function isValidJob(data) {
      return data.keys().hasAll(['clientId', 'category', 'title', 'description', 'status', 'location', 'createdAt']) &&
             data.clientId is string && data.clientId.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 5000 &&
             data.status in ['Open', 'Assigned', 'Completed'] &&
             (!('aiBudget' in data) || data.aiBudget is map);
    }

    function isValidBid(data) {
      return data.keys().hasAll(['jobId', 'clientId', 'professionalId', 'proposedPrice', 'createdAt']) &&
             data.proposedPrice is number && data.proposedPrice > 0;
    }

    function isValidAppointment(data) {
      return data.keys().hasAll(['jobId', 'bidId', 'clientId', 'professionalId', 'startTime', 'endTime', 'status', 'proposedBy', 'createdAt']) &&
             data.status in ['Proposed', 'Accepted', 'Rejected', 'Cancelled', 'Completed'];
    }

    function isValidReview(data) {
      return data.keys().hasAll(['reviewerId', 'reviewedId', 'jobId', 'stars', 'comment', 'createdAt']) &&
             data.reviewerId is string && data.reviewedId is string &&
             data.stars is number && data.stars >= 1 && data.stars <= 5;
    }

    // 2. Rules per collection

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if (isOwner(userId) || isAdmin()) && isValidUser(incoming());
      allow update: if (isValidUser(incoming()) && (
        isOwner(userId) || 
        isAdmin() || 
        (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['avgRating', 'numReviews']))
      )) && (isAdmin() || incoming().role == existing().role);
      allow delete: if isAdmin();
    }

    match /jobs/{jobId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidJob(incoming()) && incoming().clientId == request.auth.uid;
      allow update: if isSignedIn() && (
        (existing().clientId == request.auth.uid && isValidJob(incoming())) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'assignedProfessionalId'])) ||
        isAdmin()
      );
      allow delete: if isAdmin() || (isSignedIn() && existing().clientId == request.auth.uid);
    }

    match /bids/{bidId} {
      allow read: if isSignedIn() && (resource.data.professionalId == request.auth.uid || resource.data.clientId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidBid(incoming()) && incoming().professionalId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.professionalId == request.auth.uid || resource.data.clientId == request.auth.uid || isAdmin());
      allow delete: if isAdmin() || (isSignedIn() && resource.data.professionalId == request.auth.uid);
    }

    match /messages/{messageId} {
      allow read: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.recipientId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().senderId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.recipientId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['read']));
      allow delete: if isAdmin();
    }

    match /appointments/{appointmentId} {
      allow read: if isSignedIn() && (resource.data.clientId == request.auth.uid || resource.data.professionalId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidAppointment(incoming()) && (incoming().clientId == request.auth.uid || incoming().professionalId == request.auth.uid);
      allow update: if isSignedIn() && (
        (existing().clientId == request.auth.uid || existing().professionalId == request.auth.uid || isAdmin()) &&
        isValidAppointment(incoming())
      );
      allow delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidReview(incoming()) && incoming().reviewerId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // Path for connection test
    match /test/connection {
      allow read: if true;
    }
  }
}
